{
  "name": "textblock",
  "version": "2.0.0",
  "private": true,
  "description": "Hide all text in order to make the WEB beautiful",
  "scripts": {
    "build:test": "node tests/build-extension.js",
    "test": "npm run build:test && playwright test",
    "coverage": "nyc report --reporter=text --reporter=lcov --reporter=html && nyc check-coverage --lines 60 --statements 60 --functions 60 --branches 50",
    "test:coverage": "npm run test && npm run coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "nyc": "^18.0.0"
  },
  "overrides": {
    "istanbul-lib-processinfo": {
      "uuid": "^11.1.1"
    }
  },
  "nyc": {
    "all": false,
    "report-dir": "coverage",
    "temp-dir": ".nyc_output"
  }
}
