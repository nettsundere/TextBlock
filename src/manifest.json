{
  "name": "TextBlock",
  "description": "Hide all text in order to make the WEB beautiful",
  "version": "3.0",

  "manifest_version": 3,

  "permissions": [
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "http://*/",
    "https://*/"
  ],

  "icons": {
    "16": "icons/enabled/icon16.png",
    "24": "icons/enabled/icon24.png",
    "32": "icons/enabled/icon32.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/disabled/icon16.png",
      "24": "icons/disabled/icon24.png",
      "32": "icons/disabled/icon32.png"
    },
    "default_title": "Hide all text"
  },

  "background": {
    "service_worker": "service_worker.js"
  }
}
